# Dari Supabase Project Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Password untuk login ke /admin
ADMIN_PASSWORD=

# String acak panjang untuk menandatangani session admin (mis. hasil `openssl rand -hex 32`)
ADMIN_SESSION_SECRET=

# URL publik situs (tanpa trailing slash) — dipakai untuk SEO: metadata,
# Open Graph, canonical, sitemap, robots. Contoh: https://namakamu.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
